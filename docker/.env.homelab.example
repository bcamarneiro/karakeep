# Copy to docker/.env and edit before deploying:
#   cp docker/.env.homelab.example docker/.env
# Re-run `docker compose ... up -d` after any change here.

# ---- Required ----
# Generate each secret with:  openssl rand -base64 36
NEXTAUTH_SECRET=CHANGE_ME
MEILI_MASTER_KEY=CHANGE_ME
# The URL where you reach karakeep on your homelab (used for auth callbacks).
NEXTAUTH_URL=http://homelab.local:3000

# ---- Your two features ----
# Shortener resolution (search.app / share.google) needs no config — it's always on.

# Instagram text extraction (this is the opt-in flag your PR adds):
CRAWLER_INSTAGRAM_ENABLED=true
# Cookies for yt-dlp. The %% is karakeep's argument separator. The path is the
# in-container mount from docker-compose.homelab.yml. Export a logged-in
# Instagram session to docker/instagram-cookies.txt (Netscape format).
CRAWLER_YTDLP_ARGS=--cookies%%/cookies/instagram.txt
# Optional: also download reel media files (separate feature, off by default):
# CRAWLER_VIDEO_DOWNLOAD=true

# ---- Optional but recommended ----
# AI tagging/summarization runs on the extracted text. Without it the Instagram
# caption/transcript is still stored & searchable, just not auto-tagged.
# OPENAI_API_KEY=sk-...

# Lock the instance down to just you (no open registration):
# DISABLE_SIGNUPS=true
